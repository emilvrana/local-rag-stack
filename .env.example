# Local RAG Stack Configuration
# Copy this file to .env and adjust as needed

# Database Configuration
DB_HOST=localhost
DB_PORT=5433
DB_NAME=ragdb
DB_USER=raguser
DB_PASS=RagPass2025

# Service URLs
EMBEDDING_URL=http://localhost:8081/embed
LLM_URL=http://localhost:8080/v1

# LLM Configuration
LLM_MODEL_NAME=${OLLAMA_MODEL:-qwen2.5:7b}
LLM_TEMPERATURE=0.7
LLM_MAX_CONTEXT=4096

# Ollama Model (used when llm service starts)
# Options: qwen2.5:7b, qwen2.5:14b, llama3.2, mistral, etc.
OLLAMA_MODEL=qwen2.5:7b

# Chunking Settings
CHUNK_SIZE=500
CHUNK_OVERLAP=50
DEFAULT_TOP_K=3
